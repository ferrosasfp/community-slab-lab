{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }]
    },
    {
      "source": "/(.*\\.css)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
